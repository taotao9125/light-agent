{
  "name": "@light-agent/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "light-agent-cli": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "watch": "tsgo -w -p tsconfig.build.json",
    "build": "tsgo -p tsconfig.build.json && shx chmod +x dist/index.js"
  },
  "dependencies": {
    "@light-agent/ai": "workspace:*",
    "@light-agent/agent": "workspace:*",
    "dotenv": "^16.4.5",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  }
}
