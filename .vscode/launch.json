{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "attach",
      "name": "debug express",
      "port": 9229, // Node 默认调试端口
      "restart": true, // nodemon 重启时，调试器也会自动重连
      "cwd": "${workspaceFolder}/server",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}