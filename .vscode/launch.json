{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AGENT",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "program": "${workspaceFolder}/agent/src/cli/index.ts",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/agent",
      "skipFiles": [
        "<node_internals>/**",
       "node_modules/**"
      ]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "debug express",
      "port": 9229, // Node 默认调试端口
      "restart": true, // nodemon 重启时，调试器也会自动重连
      "cwd": "${workspaceFolder}/server",
      "skipFiles": [
        "<node_internals>/**",
        "node_modules/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug workflow index",
      "cwd": "${workspaceFolder}/mcp_server",
      "runtimeExecutable": "${env:HOME}/.nvm/versions/node/v24.14.1/bin/node",
      "program": "${workspaceFolder}/mcp_server/src/index.js",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/mcp_server/node_modules/**"
      ]
    }
  ]
}