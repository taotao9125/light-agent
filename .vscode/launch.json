{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Pnpm Workspace Debug",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "--filter", "server", // 这里的名字要和 package.json 里的 name 一致
        "exec",
        "nodemon",
        "./bin/www"
      ],
      "restart": true,
      "console": "integratedTerminal"
    }
  ]
}